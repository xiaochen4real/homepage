---
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
---

<Layout title="YSYX">

  <SiteHeader />

  <main class="mx-auto min-h-screen max-w-3xl px-8 py-24">

    <a
      href="/projects"
      class="text-neutral-500 transition hover:text-black"
    >

    </a>

    <h1 class="mt-10 text-5xl font-bold tracking-tight">
      One Student One Chip (YSYX)
    </h1>

    <p class="mt-6 text-lg leading-8 text-neutral-600">
      Learning computer architecture by building a RISC-V processor
      from scratch.
    </p>

    <div class="mt-16 rounded-2xl border border-neutral-200 p-8">

      <h2 class="text-xl font-semibold">
        Status
      </h2>

      <p class="mt-4 text-neutral-600">
        🚧 In Progress
      </p>

    </div>

  </main>

</Layout>