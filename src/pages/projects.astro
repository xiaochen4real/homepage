---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
---

<Layout title="Projects">

  <SiteHeader />

  <main class="mx-auto min-h-screen max-w-4xl px-8 py-24">

    <h1 class="text-5xl font-bold tracking-tight">
      Projects
    </h1>

    <p class="mt-6 max-w-2xl text-lg leading-8 text-neutral-600">
      Selected work and ongoing learning in digital design,
      computer architecture, and hardware systems.
    </p>

    <section class="mt-20">

      <a
        href="/projects/ysyx"
        class="block rounded-2xl border border-neutral-200 p-8 transition hover:border-neutral-400 hover:shadow-sm"
      >

        <div class="flex items-center justify-between">

          <h2 class="text-2xl font-semibold">
            One Student One Chip (YSYX)
          </h2>

          <span
            class="rounded-full bg-green-100 px-3 py-1 text-sm text-green-700"
          >
            In Progress
          </span>

        </div>

        <p class="mt-5 max-w-2xl leading-8 text-neutral-600">
          Learning computer architecture by building a RISC-V processor
          from scratch.
        </p>

      </a>

    </section>

  </main>
</Layout>