---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main
    class="mx-auto flex min-h-screen max-w-3xl flex-col items-center justify-center px-8 text-center"
  >
    <img
      src="/logo.svg"
      alt="Chen Xiao Logo"
      class="mb-8 h-14 w-14"
    />

    <h1
      class="text-7xl font-bold tracking-[-0.05em] text-neutral-900"
    >
      Chen Xiao
    </h1>

    <p
      class="mt-8 text-2xl font-medium text-neutral-700"
    >
      ASIC Design Engineer
    </p>

    <p
      class="mt-10 max-w-2xl text-xl leading-9 text-neutral-600"
    >
      Passionate about digital design, computer architecture,
      and hardware systems.
    </p>

    <nav
      class="mt-16 flex flex-wrap justify-center gap-8 text-lg text-neutral-700"
    >
      <a
        href="/projects"
        class="transition-colors duration-200 hover:text-black"
      >
        Projects
      </a>

      <a
        href="/blog"
        class="transition-colors duration-200 hover:text-black"
      >
        Blog
      </a>

      <a
        href="https://github.com/xiaochen4real"
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors duration-200 hover:text-black"
      >
        GitHub
      </a>

      <a
        href="mailto:me@chenxiao.me"
        class="transition-colors duration-200 hover:text-black"
      >
        Email
      </a>
    </nav>
  </main>
</Layout>